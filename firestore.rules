rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // 【セットアップ手順】
    // 1. アプリにGoogleログインする
    // 2. ダッシュボード上部のバナーに表示されるUIDをコピーする
    // 3. 2人分のUIDを下記リストに貼り付ける
    // 4. firebase deploy --only firestore:rules で再デプロイする
    // ============================================================

    function isAllowed() {
      return request.auth != null
          && request.auth.uid in [
            "oauPGkK9XwUjkJMiOGSer9NJJxu2",   // 本人（夫）
            "ADoH8r9AtSMeF0KzL3XrSmGPkMU2"    // 妻
          ];
    }

    // 家族データへのアクセスは許可された2人のみ
    match /households/{householdId}/{document=**} {
      allow read, write: if isAllowed();
    }

    // その他すべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
